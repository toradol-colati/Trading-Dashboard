        .option-btn span { margin-top: 5px; font-weight: 500; }

        /* UI Elements */
        .add-btn { background: rgba(0, 255, 65, 0.05); color: var(--accent); border: 1px solid var(--accent); padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 0.7rem; text-transform: uppercase; font-weight: bold; }
        .controls { position: fixed; bottom: 20px; right: 20px; display: flex; gap: 10px; z-index: 200; }
        textarea#exportArea { position: fixed; top: 10%; left: 10%; width: 80%; height: 70%; background: #000; color: var(--accent); z-index: 1000; display: none; border: 1px solid var(--accent); padding: 20px; font-family: monospace; }
    </style>
</head>
<body>

    <nav id="sidebar"></nav>

    <div id="content-wrapper"></div>

    <div class="controls">
        <button class="add-btn" onclick="addTopic()">+ AMBIENTE</button>
        <button class="add-btn" style="border-color: #ff9800; color: #ff9800;" onclick="toggleExport()">EXPORT CONFIG</button>
    </div>

    <textarea id="exportArea" placeholder="JSON output..."></textarea>

<script>
    // I TUOI DATI ORIGINALI INTEGRATI (NON TOCCATI)
    let data = {
        "topics": [
            { "id": "trading", "name": "Chart Analysis 📈", "icon": "fa-chart-line", "subsections": [
                { "name": "Crypto 📲💹", "options": [
                    { "name": "BTCEUR (tv)", "url": "https://it.tradingview.com/chart/R4T4rycM/?symbol=COINBASE%3ABTCEUR" },
                    { "name": "Glassnode", "url": "https://studio.glassnode.com/" },
                    { "name": "Messari", "url": "https://messari.io/" },
                    { "name": "DexScreener", "url": "https://dexscreener.com/" },
                    { "name": "DefiLlama", "url": "https://defillama.com/" },
                    { "name": "Dune", "url": "https://dune.com/home" },
                    { "name": "Arkham", "url": "https://intel.arkm.com/" }
                ]},
                { "name": "General 📊", "options": [
                    { "name": "MacroMicro", "url": "https://en.macromicro.me/macro/us" },
                    { "name": "TradingEconomics", "url": "https://tradingeconomics.com/" },
                    { "name": "FRED", "url": "https://fred.stlouisfed.org/" },
                    { "name": "ForexFactory", "url": "https://www.forexfactory.com/" }
                ]}
            ]},
            { "id": "news", "name": "News Feed 🌎", "icon": "fa-rss", "subsections": [
                { "name": "Crypto", "options": [
                    { "name": "cryptopanic", "url": "https://cryptopanic.com/" },
                    { "name": "CoinTelegraph", "url": "https://it.cointelegraph.com/" },
                    { "name": "CoinMarketCap", "url": "https://coinmarketcap.com/" },
                    { "name": "CoinDesk", "url": "https://www.coindesk.com/it" },
                    { "name": "TheBlock", "url": "https://www.theblock.co/" }
                ]},
                { "name": "General", "options": [
                    { "name": "Bloomberg", "url": "https://www.bloomberg.com/europe" },
                    { "name": "FinancialTimes", "url": "https://www.ft.com/" },
                    { "name": "Reuters", "url": "https://www.reuters.com/" },
                    { "name": "ilSole24ore", "url": "https://www.ilsole24ore.com/" }
                ]}
            ]},
            { "id": "brokers", "name": "Brokers 👔", "icon": "fa-briefcase", "subsections": [
                { "name": "Active", "options": [
                    { "name": "Robinhood", "url": "https://robinhood.com/eu/it/" },
                    { "name": "YngPlatform", "url": "https://youngplatform.com/" },
                    { "name": "IBKR", "url": "https://www.interactivebrokers.com/" }
                ]},
                { "name": "Non-active", "options": [
                    { "name": "Coinbase", "url": "https://login.coinbase.com/signin" },
                    { "name": "Binance", "url": "https://www.binance.com/it" },
                    { "name": "YouHodler", "url": "https://www.youhodler.com/it" },
                    { "name": "TradeRepublic", "url": "https://traderepublic.com/it-it" }
                ]}
            ]},
            { "id": "algo", "name": "Algo-Trading 🤖", "icon": "fa-robot", "subsections": [
                { "name": "Dal web 🛜", "options": [] },
                { "name": "Research 📝", "options": [] }
            ]},
            { "id": "academy", "name": "E-cademics 📚", "icon": "fa-graduation-cap", "subsections": [
                { "name": "e-Courses 📺", "options": [] },
                { "name": "Files📕", "options": [] }
            ]},
            { "id": "pac", "name": "PAC Savings 🐖", "icon": "fa-piggy-bank", "subsections": [] }
        ]
    };

    function init() {
        const sidebar = document.getElementById('sidebar');
        const wrapper = document.getElementById('content-wrapper');
        sidebar.innerHTML = '';
        wrapper.innerHTML = '';

        data.topics.forEach((topic, tIdx) => {
            const iconWrap = document.createElement('div');
            iconWrap.className = `nav-icon ${tIdx === 0 ? 'active' : ''}`;
            iconWrap.id = `nav-${topic.id}`;
            iconWrap.innerHTML = `<i class="fas ${topic.icon}"></i>`;
            iconWrap.onclick = () => switchTab(topic.id);
            sidebar.appendChild(iconWrap);

            const main = document.createElement('main');
            main.id = `page-${topic.id}`;
            if(tIdx === 0) main.className = 'active';

            let sectionsHtml = '';
            topic.subsections.forEach((sub, sIdx) => {
                sectionsHtml += `
                    <div class="sub-section">
                        <div class="sub-title">
                            ${sub.name} 
                            <button class="add-btn" onclick="addOption(${tIdx}, ${sIdx})">+ OPT</button>
                        </div>
                        <div class="grid">
                            ${sub.options.map(opt => `
                                <a href="${opt.url}" target="_blank" class="option-btn">
                                    <span>${opt.name}</span>
                                </a>
                            `).join('')}
                        </div>
                    </div>`;
            });

            main.innerHTML = `
                <header>
                    <h1>${topic.name}</h1>
                    <button class="add-btn" onclick="addSub(${tIdx})">+ SUB-SEZIONE</button>
                </header>
                ${sectionsHtml}
            `;
            wrapper.appendChild(main);
        });
    }

    function switchTab(id) {
        document.querySelectorAll('main').forEach(m => m.classList.remove('active'));
        document.querySelectorAll('.nav-icon').forEach(i => i.classList.remove('active'));
        document.getElementById(`page-${id}`).classList.add('active');
        document.getElementById(`nav-${id}`).classList.add('active');
    }

    function addTopic() {
        const name = prompt("Nome Ambiente (es. Forex):");
        if(name) {
            const id = name.toLowerCase().replace(/\s/g, '-');
            data.topics.push({ id, name, icon: "fa-folder", subsections: [] });
            init();
        }
    }

    function addSub(tIdx) {
        const name = prompt("Nome Sottosezione:");
        if(name) {
            data.topics[tIdx].subsections.push({ name, options: [] });
            init();
        }
    }

    function addOption(tIdx, sIdx) {
        const name = prompt("Nome Opzione:");
        const url = prompt("URL:");
        if(name && url) {
            data.topics[tIdx].subsections[sIdx].options.push({ name, url });
            init();
        }
    }

    function toggleExport() {
        const area = document.getElementById('exportArea');
        area.style.display = area.style.display === 'block' ? 'none' : 'block';
        area.value = JSON.stringify(data, null, 2);
    }

    init();
</script>
</body>
</html>
