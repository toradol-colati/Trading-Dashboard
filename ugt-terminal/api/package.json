{
  "name": "ugt-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate up --database-url-var DATABASE_URL --migrations-dir src/db/migrations --migration-file-language sql",
    "migrate:down": "node-pg-migrate down --database-url-var DATABASE_URL --migrations-dir src/db/migrations --migration-file-language sql",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/websocket": "^10.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/cors": "^9.0.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.0",
    "pino": "^9.2.0",
    "zod": "^3.23.0",
    "node-pg-migrate": "^7.5.0",
    "csv-parse": "^5.5.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "vitest": "^2.0.0"
  }
}
